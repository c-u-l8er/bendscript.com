{
  "name": "@bendscript/core",
  "version": "0.1.0-alpha.0",
  "description": "Reference parser, validator, and round-trip harness for the BendScript Protocol v0.1 — a graph-first document format with typed inline link facets, for agent-native systems.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./harness": {
      "types": "./dist/harness/index.d.ts",
      "import": "./dist/harness/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "bendscript",
    "graph",
    "knowledge-graph",
    "document",
    "parser",
    "validator",
    "agent",
    "ampersand"
  ],
  "license": "MIT",
  "author": "Travis Burandt",
  "homepage": "https://bendscript.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c-u-l8er/bendscript.com.git"
  },
  "bugs": {
    "url": "https://github.com/c-u-l8er/bendscript.com/issues"
  },
  "dependencies": {
    "canonicalize": "^2.0.0",
    "multiformats": "^13.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
