# -----------------------------------------------------------------------------
# BendScript Environment Template
# Copy this file to `.env` (local) and fill in real values.
# -----------------------------------------------------------------------------

# App
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_APP_NAME=BendScript
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Optional: direct Postgres URL for local tooling/scripts
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# AI (Anthropic via server proxy / edge function)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_FAST_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MAX_TOKENS=2048

# Optional pricing/rate controls
AI_FREE_TIER_MONTHLY_LIMIT=100
AI_TEAM_TIER_MONTHLY_LIMIT=5000
AI_ENTERPRISE_TIER_MONTHLY_LIMIT=20000

# -----------------------------------------------------------------------------
# API / MCP
# -----------------------------------------------------------------------------
MCP_SERVER_NAME=bendscript-mcp
MCP_SERVER_VERSION=0.1.0
API_RATE_LIMIT_PER_MINUTE=60
API_KEY_PREFIX=bsk_

# -----------------------------------------------------------------------------
# Sharing / URLs
# -----------------------------------------------------------------------------
PUBLIC_SHARE_BASE_URL=http://localhost:5173/share
PUBLIC_DOCS_URL=https://docs.bendscript.com
